# ===========================================
# GymFlow Track Environment Configuration
# Copy this to .env and fill in values
# ===========================================

# Database
DATABASE_URL=postgresql+asyncpg://gymflowtrack:gymflowtrack@localhost:5432/gymflowtrack
DATABASE_URL_SYNC=postgresql://gymflowtrack:gymflowtrack@localhost:5432/gymflowtrack

# JWT
JWT_SECRET_KEY=change-this-to-a-random-64-char-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_NAME=GymFlow Track
APP_ENV=development
DEBUG=true
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# CORS
CORS_ORIGINS=http://localhost:3000

# Email (Resend — https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxx
RESEND_FROM_EMAIL=GymFlow <onboarding@resend.dev>

# WhatsApp (Phase 2)
# WHATSAPP_API_KEY=
# WHATSAPP_PHONE_NUMBER_ID=
