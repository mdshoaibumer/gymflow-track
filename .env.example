# ===========================================
# GymFlow Environment Configuration
# Copy this to .env and fill in values
# ===========================================

# Database
DATABASE_URL=postgresql+asyncpg://gymflow:gymflow@localhost:5432/gymflow
DATABASE_URL_SYNC=postgresql://gymflow:gymflow@localhost:5432/gymflow

# JWT
JWT_SECRET_KEY=change-this-to-a-random-64-char-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_NAME=GymFlow
APP_ENV=development
DEBUG=true
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# CORS
CORS_ORIGINS=http://localhost:3000

# WhatsApp (Phase 2)
# WHATSAPP_API_KEY=
# WHATSAPP_PHONE_NUMBER_ID=
