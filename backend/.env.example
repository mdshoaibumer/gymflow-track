# ============================================================
# GymFlow Track Backend — Environment Configuration
# ============================================================
# Copy to .env and adjust for your environment.
# In production, use platform secrets (Railway/Render/Fly) instead.

# --- App ---
APP_NAME=GymFlow Track
APP_ENV=development          # development | staging | production
DEBUG=true                   # MUST be false in production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# --- Database ---
DATABASE_URL=postgresql+asyncpg://gymflow:gymflow@localhost:5432/gymflow
DATABASE_URL_SYNC=postgresql://gymflow:gymflow@localhost:5432/gymflow
DB_POOL_SIZE=5               # Connections in pool (increase for prod)
DB_MAX_OVERFLOW=10           # Extra connections above pool size
DB_POOL_TIMEOUT=30           # Seconds to wait for a connection

# --- JWT ---
# CRITICAL: Change in staging/production!
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS ---
# Comma-separated origins. Set to your frontend domain in production.
CORS_ORIGINS=http://localhost:3000

# --- Rate Limiting ---
RATE_LIMIT_AUTH=10           # Auth attempts per minute per IP
RATE_LIMIT_API=100           # API requests per minute per IP

# --- WhatsApp ---
WHATSAPP_PROVIDER=log_only   # log_only | aisensy
WHATSAPP_API_KEY=

# --- Password Policy ---
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128

# --- Razorpay (Payment Gateway) ---
# Set to "mock" for development (no real payments)
# Get keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=mock
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Billing ---
TRIAL_DAYS=3                 # Free trial duration in days
