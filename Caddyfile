# ==============================================================
# GymFlow Track — Caddy Reverse Proxy (Production)
# ==============================================================
# Automatic HTTPS via Let's Encrypt / ZeroSSL
# Cloudflare DNS must point A records to this server's IP
#
# Subdomains:
#   app.gymflowtrack.in   → Frontend (Next.js)
#   admin.gymflowtrack.in → Frontend /admin routes
#   api.gymflowtrack.in   → Backend (FastAPI)
#
# Security: HSTS preload, CSP, CORS hardening, request size limits
# ==============================================================

# Global options
{
	email {$ACME_EMAIL:admin@gymflowtrack.in}

	# Staging CA for testing (uncomment to avoid rate limits during setup):
	# acme_ca https://acme-staging-v02.api.letsencrypt.org/directory

	# Restrict admin API to localhost only
	admin off

	# Global request body size limit (10MB max)
	servers {
		max_header_size 16kb
	}
}

# ── Shared security headers snippet ─────────────────────────
(security_headers) {
	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
		X-XSS-Protection "0"
		# Remove server identity
		-Server
		-X-Powered-By
	}
}

# ── App Frontend ─────────────────────────────────────────────
app.gymflowtrack.in {
	encode gzip zstd

	import security_headers

	# Cache static assets aggressively
	@static path /_next/static/* /static/* *.ico *.png *.jpg *.svg *.woff2
	header @static Cache-Control "public, max-age=31536000, immutable"

	reverse_proxy frontend:3000 {
		health_uri /
		health_interval 30s
		health_timeout 5s

		# Retry on connection failure (zero-downtime deploys)
		lb_try_duration 5s
		lb_try_interval 250ms
	}
}

# ── Admin Portal ─────────────────────────────────────────────
admin.gymflowtrack.in {
	encode gzip zstd

	import security_headers

	@static path /_next/static/* /static/* *.ico *.png *.jpg *.svg *.woff2
	header @static Cache-Control "public, max-age=31536000, immutable"

	reverse_proxy frontend:3000 {
		health_uri /
		health_interval 30s
		health_timeout 5s

		lb_try_duration 5s
		lb_try_interval 250ms
	}
}

# ── Backend API ──────────────────────────────────────────────
api.gymflowtrack.in {
	encode gzip zstd

	import security_headers

	# Request body size limit for API (1MB default, overridden for upload paths)
	request_body {
		max_size 1MB
	}

	# Explicit CORS — do NOT reflect arbitrary origins
	# CORS is handled by FastAPI middleware. Caddy should NOT add its own
	# Access-Control-Allow-Origin header to avoid double-header conflicts.
	# The old config reflected any Origin which bypasses CORS entirely.

	# Health check endpoint — no auth required, lightweight
	handle /health* {
		reverse_proxy backend:8000
	}

	# API routes
	handle /api/* {
		reverse_proxy backend:8000 {
			# Pass real client IP (Cloudflare → Caddy → Backend)
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
			header_up X-Forwarded-Host {host}

			health_uri /health/live
			health_interval 30s
			health_timeout 5s

			# Retry on connection failure (zero-downtime deploys)
			lb_try_duration 5s
			lb_try_interval 250ms

			# Timeouts
			transport http {
				read_timeout 30s
				write_timeout 30s
				dial_timeout 5s
			}
		}
	}

	# Block all other paths on the API domain
	handle {
		respond "Not Found" 404
	}
}

# ── Root Domain → Redirect to app ───────────────────────────
gymflowtrack.in {
	redir https://app.gymflowtrack.in{uri} permanent
}

www.gymflowtrack.in {
	redir https://gymflowtrack.in{uri} permanent
}
