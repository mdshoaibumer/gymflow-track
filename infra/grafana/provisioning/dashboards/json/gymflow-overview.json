{
  "annotations": {
    "list": [
      {
        "datasource": "Prometheus",
        "enable": true,
        "expr": "changes(process_start_time_seconds{job=\"gymflow-backend\"}[1m]) > 0",
        "name": "Backend Restarts",
        "iconColor": "red"
      }
    ]
  },
  "editable": true,
  "title": "GymFlow Track — Production Overview",
  "uid": "gymflow-overview",
  "version": 1,
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"gymflow-backend\"}[5m])",
          "legendFormat": "{{method}} {{handler}}",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "title": "Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"gymflow-backend\",status=~\"5..\"}[5m])",
          "legendFormat": "{{status}}",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "title": "P95 Latency (seconds)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"gymflow-backend\"}[5m]))",
          "legendFormat": "P95",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{job=\"gymflow-backend\"}[5m]))",
          "legendFormat": "P50",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "title": "CPU Usage (%)",
      "type": "gauge",
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\",job=\"node-exporter\"}[5m])) * 100)",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {"value": 0, "color": "green"},
              {"value": 70, "color": "yellow"},
              {"value": 85, "color": "red"}
            ]
          },
          "unit": "percent",
          "max": 100
        }
      }
    },
    {
      "title": "Memory Usage (%)",
      "type": "gauge",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 8},
      "targets": [
        {
          "expr": "(1 - node_memory_MemAvailable_bytes{job=\"node-exporter\"} / node_memory_MemTotal_bytes{job=\"node-exporter\"}) * 100",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {"value": 0, "color": "green"},
              {"value": 80, "color": "yellow"},
              {"value": 90, "color": "red"}
            ]
          },
          "unit": "percent",
          "max": 100
        }
      }
    },
    {
      "title": "Disk Usage (%)",
      "type": "gauge",
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\",job=\"node-exporter\"} / node_filesystem_size_bytes{mountpoint=\"/\",job=\"node-exporter\"}) * 100",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {"value": 0, "color": "green"},
              {"value": 80, "color": "yellow"},
              {"value": 90, "color": "red"}
            ]
          },
          "unit": "percent",
          "max": 100
        }
      }
    },
    {
      "title": "Active DB Connections",
      "type": "stat",
      "gridPos": {"h": 8, "w": 6, "x": 6, "y": 16},
      "targets": [
        {
          "expr": "pg_stat_activity_count",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {"value": 0, "color": "green"},
              {"value": 35, "color": "yellow"},
              {"value": 45, "color": "red"}
            ]
          },
          "max": 50
        }
      }
    },
    {
      "title": "Application Logs",
      "type": "logs",
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 24},
      "targets": [
        {
          "expr": "{service=\"backend\"} |~ \"ERROR|WARN|CRITICAL\"",
          "datasource": "Loki"
        }
      ]
    }
  ],
  "time": {"from": "now-6h", "to": "now"},
  "refresh": "30s"
}
