# ============================================================
# GymFlow Track — Production Environment Configuration
# ============================================================
# Copy to .env and fill in ALL values marked CHANGE_ME
#
# SECURITY: This file contains secrets. Never commit .env to git.
#
# Secret generation commands:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
#   openssl rand -hex 32
# ============================================================

# === App ===
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO

# === Domain ===
COOKIE_DOMAIN=.gymflowtrack.in
ALLOWED_HOSTS=api.gymflowtrack.in

# === Database ===
POSTGRES_USER=gymflow
POSTGRES_PASSWORD=CHANGE_ME_STRONG_RANDOM_PASSWORD
POSTGRES_DB=gymflow
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# === Redis ===
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# === JWT ===
# CRITICAL: Must be at least 32 characters. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_USE_python3_-c_import_secrets_print_secrets_token_hex_32

# === CORS ===
CORS_ORIGINS=https://app.gymflowtrack.in,https://admin.gymflowtrack.in

# === Frontend ===
NEXT_PUBLIC_API_URL=https://api.gymflowtrack.in/api/v1

# === Razorpay (Payment Gateway) ===
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=CHANGE_ME
RAZORPAY_WEBHOOK_SECRET=CHANGE_ME

# === WhatsApp ===
WHATSAPP_PROVIDER=log_only
WHATSAPP_API_KEY=

# === Monitoring ===
SENTRY_DSN=
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# === ACME (Caddy TLS) ===
ACME_EMAIL=admin@gymflowtrack.in

# === Backup ===
BACKUP_DIR=/opt/gymflow/backups
RETENTION_DAYS=30
# Optional: AES-256 encryption key for backup files
# Generate: openssl rand -hex 32
BACKUP_ENCRYPTION_KEY=

# === Cloudflare R2 (Offsite Backup) ===
# Optional: Configure for offsite backup storage
R2_BUCKET=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
